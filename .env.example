SERVER_HOST=127.0.0.1
SERVER_PORT=8080
COMPRESSION_LEVEL=22
ENABLE_MEDIA_TRANSCODE=false
FFMPEG_BIN=ffmpeg
FFMPEG_VIDEO_CRF=28
